# Base URLs are required at import time: the better-auth server instance
# (src/lib/auth/auth.ts) validates `baseURL` when the module initializes, so an
# unset VITE_BASE_URL throws "Invalid base URL: null" and fails the whole run.
VITE_BASE_URL="https://localhost:3000"
VITE_API_BASE_URL="https://localhost:4000"
VITE_AUTH_BASE_URL="https://localhost:8000"
# TODO change this once tests implemented, can mock with MSW
VITE_AUTH_ISSUER="https://localhost:8000/api/auth"
